# Required environment variables
# Copy this file to .env.local (for local development) or .env.production and fill in your values.

# The canonical URL of your site (no trailing slash)
# Used for metadata, canonical links, sitemap, and robots.txt.
# Example: https://mywebsite.com
NEXT_PUBLIC_SITE_URL=https://example.com
NODE_ENV=development

# Optional – Cloudinary cloud name for image optimization.
# Leave empty to use the default Next.js image optimization.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Optional – Webhook URL for contact form submissions.
# When set, the contact form Server Action will POST submissions here.
# When unset, submissions are logged to the server console (development mode).
CONTACT_FORM_WEBHOOK_URL=